# Playwright Toolkit — Environment Configuration Template
# Copy to .env and adjust paths for your machine.

# Path to Chrome's user data directory (for profile-based auth)
CHROME_PROFILE=/path/to/chrome/profile

# Path to extracted cookies JSON (generated by extract-cookies.mjs)
COOKIES_FILE=/tmp/cookies.json

# Directory for generated outputs (screenshots, images)
OUTPUT_DIR=./output

# Chrome DevTools Protocol port (for CDP connection)
CDP_PORT=9222

# Root directory of the Playwright Toolkit
PLAYWRIGHT_DIR=.
